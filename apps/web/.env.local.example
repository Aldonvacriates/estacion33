# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit real keys.

NEXT_PUBLIC_SUPABASE_URL=https://odzqcbbnkwkwkdajtswf.supabase.co
# "Publishable key" in the new Supabase naming (was "anon" key).
# Safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# MercadoPago — TEST credentials only. Production keys never live in this file.
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-...

# WhatsApp number for "Confirmar por WhatsApp" buttons on order + reservation
# confirmation pages. Digits only, no '+' or spaces. Mexico = "52" + area code
# + 7 digits (mobile numbers usually need a leading "1" after the 52, e.g.
# 52 1 733 107 4642 -> 5217331074642). Set the same value in Vercel for
# Production + Preview + Development.
NEXT_PUBLIC_WHATSAPP_NUMBER=5217331074642
