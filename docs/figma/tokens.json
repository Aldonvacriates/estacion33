        "value": { "x": "0", "y": "1", "blur": "2", "spread": "0", "color": "rgba(15,15,15,0.08)", "type": "dropShadow" },
        "type": "boxShadow"
      },
      "md": {
        "value": { "x": "0", "y": "4", "blur": "8", "spread": "0", "color": "rgba(15,15,15,0.10)", "type": "dropShadow" },
        "type": "boxShadow"
      },
      "lg": {
        "value": { "x": "0", "y": "12", "blur": "24", "spread": "0", "color": "rgba(15,15,15,0.14)", "type": "dropShadow" },
        "type": "boxShadow"
      }
    },

    "size": {
      "tap":         { "value": "44", "type": "sizing", "description": "Min mobile tap target" },
      "buttonSm":    { "value": "32", "type": "sizing" },
      "buttonMd":    { "value": "40", "type": "sizing" },
      "buttonLg":    { "value": "48", "type": "sizing" },
      "inputMd":     { "value": "44", "type": "sizing" },
      "appBar":      { "value": "56", "type": "sizing" },
      "bottomNav":   { "value": "64", "type": "sizing" },
      "containerSm": { "value": "640",  "type": "sizing" },
      "containerMd": { "value": "768",  "type": "sizing" },
      "containerLg": { "value": "1024", "type": "sizing" },
      "containerXl": { "value": "1280", "type": "sizing" },
      "containerMax":{ "value": "1440", "type": "sizing" }
