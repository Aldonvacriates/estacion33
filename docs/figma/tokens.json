        "primaryHover": { "value": "#6D9533", "type": "color" },
        "primaryActive": { "value": "#5E822C", "type": "color" },
        "primaryDark": { "value": "#2A3815", "type": "color", "description": "Nav, footer, dark surfaces" },
        "primary50":  { "value": "#F4F8EC", "type": "color" },
        "primary100": { "value": "#E5EFD0", "type": "color" },
        "primary200": { "value": "#CCDFA1", "type": "color" },
        "primary300": { "value": "#B2CF72", "type": "color" },
        "primary400": { "value": "#99BF5A", "type": "color" },
        "primary500": { "value": "#7DA640", "type": "color" },
        "primary600": { "value": "#6D9533", "type": "color" },
        "primary700": { "value": "#577827", "type": "color" },
        "primary800": { "value": "#3F571B", "type": "color" },
        "primary900": { "value": "#2A3815", "type": "color" },

        "secondary": { "value": "#FE9F10", "type": "color", "description": "Accent orange — badges, highlights" },
        "secondaryHover": { "value": "#E58E08", "type": "color" },
        "secondary50":  { "value": "#FFF6E6", "type": "color" },
        "secondary100": { "value": "#FFE2B8", "type": "color" },
