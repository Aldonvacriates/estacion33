        "yellow50":  { "value": "#FFF8DD", "type": "color" },
        "yellow500": { "value": "#F6C42A", "type": "color" },
        "yellow700": { "value": "#B0890A", "type": "color" },

        "char":   { "value": "#0F0F0F", "type": "color", "description": "Charcoal — menu page background" }
