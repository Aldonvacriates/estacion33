        "dangerFg":     { "value": "#7F1D1D", "type": "color" },
        "info":         { "value": "#2563EB", "type": "color" },
        "infoBg":       { "value": "#DBEAFE", "type": "color" },
        "infoFg":       { "value": "#1E3A8A", "type": "color" }
      },
      "surface": {
        "bg":         { "value": "{color.neutral.0}",   "type": "color" },
        "bgMuted":    { "value": "{color.neutral.50}",  "type": "color" },
        "bgRaised":   { "value": "{color.neutral.0}",   "type": "color" },
        "bgInverse":  { "value": "{color.brand.primaryDark}", "type": "color" },
        "border":     { "value": "{color.neutral.200}", "type": "color" },
        "borderStrong": { "value": "{color.neutral.300}", "type": "color" },
