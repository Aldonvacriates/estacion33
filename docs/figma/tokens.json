      "semantic": {
        "success":      { "value": "#16A34A", "type": "color" },
        "successBg":    { "value": "#DCFCE7", "type": "color" },
        "successFg":    { "value": "#14532D", "type": "color" },
        "warning":      { "value": "#F59E0B", "type": "color" },
        "warningBg":    { "value": "#FEF3C7", "type": "color" },
